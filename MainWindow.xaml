<Window x:Class="ServiceManagementXAML.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ServiceManagementXAML"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label Content="Service Name:" HorizontalAlignment="Left" Margin="128,69,0,0" VerticalAlignment="Top" FontFamily="Microsoft Sans Serif" FontWeight="Bold" FontSize="20"/>
        <Label Content="Service Status:" HorizontalAlignment="Left" Margin="128,126,0,0" VerticalAlignment="Top" FontFamily="Microsoft Sans Serif" FontWeight="Bold" FontSize="20"/>
        <ComboBox x:Name="ServiceDropDown" HorizontalAlignment="Left" Margin="318,74,0,0" VerticalAlignment="Top" Width="278"/>
        <Label Content="Actions:" HorizontalAlignment="Left" Margin="128,184,0,0" VerticalAlignment="Top" FontFamily="Microsoft Sans Serif" FontWeight="Bold" FontSize="20"/>
        <Button x:Name="RestartButton" Content="Restart" HorizontalAlignment="Left" Margin="318,187,0,0" VerticalAlignment="Top" Height="27" Width="66"/>
        <Button x:Name="StartButton" Content="Start" HorizontalAlignment="Left" Margin="424,187,0,0" VerticalAlignment="Top" Height="27" Width="66"/>
        <Button x:Name="StopButton" Content="Stop" HorizontalAlignment="Left" Margin="530,187,0,0" VerticalAlignment="Top" Height="27" Width="66"/>
        <Label x:Name="Status" Content="" HorizontalAlignment="Left" Margin="318,128,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.163,0.109" Width="82" FontFamily="Microsoft Sans Serif" FontSize="18"/>
        <Label x:Name="CurrentActionLabel" Content="" HorizontalAlignment="Left" Margin="132,251,0,0" VerticalAlignment="Top" Width="464" FontFamily="Microsoft Sans Serif" FontSize="20"/>

    </Grid>
</Window>
